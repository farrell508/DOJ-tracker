{
  "manifest_version": 3,
  "name": "DOJ Tracker",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://discord.com/*", "https://dojoi.xyz/*"],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://dojoi.xyz/*"],
      "js": ["content.js"]
    }
  ]
}